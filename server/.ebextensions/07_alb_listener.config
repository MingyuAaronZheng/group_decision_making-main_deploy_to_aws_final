option_settings:
  # ---- tell EB to keep using Gunicorn when no rule matches ----
  aws:elbv2:listener:80:
    DefaultProcess: http          # "http" is the process name in processes.yaml
    ListenerEnabled: 'true'
    Protocol: HTTP
    Rules: ws                     # attach the rule block called "ws"

  # ---- This is the rule block EB will generate ----
  aws:elbv2:listenerrule:ws:
    PathPatterns: /ws/*           # pattern to match
    Process: websocket            # forward to Daphne target group
    Priority: 1                   # must be unique per listener

  # ---- expose both processes so EB creates the two target groups ----
  aws:elasticbeanstalk:environment:process:http:
    Port: '8000'
    Protocol: HTTP
  aws:elasticbeanstalk:environment:process:websocket:
    Port: '5000'
    Protocol: HTTP
